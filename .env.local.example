# Supabase（https://supabase.com のプロジェクト設定 > API から取得）
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Groq（https://console.groq.com/keys から取得・無料）
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ホットペッパーグルメ（https://webservice.recruit.co.jp/ から取得・無料）
HOTPEPPER_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxx
